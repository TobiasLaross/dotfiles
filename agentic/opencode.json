{
  "$schema": "https://opencode.ai/config.json",
  "model": "github-copilot/claude-opus-4.6",
  "instructions": ["~/.claude/CLAUDE.md"],
  "permission": {
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "skill": "allow",
    "bash": "allow",
    "external_directory": {
      "~/.claude/**": "allow",
      "~/.claude/repo-context/*": "allow",
      "~/Developer/work/**": "allow",
      "~/Developer/personal/**": "allow",
      "~/dotfiles/**": "allow",
      "/tmp/**": "allow"
    }
  }
}
