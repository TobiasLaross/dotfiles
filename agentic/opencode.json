{
  "$schema": "https://opencode.ai/config.json",
  "model": "github-copilot/claude-opus-4.6",
  "lsp": true,
  "mcp": {
    "atlassian": {
      "type": "local",
      "command": ["npx", "-y", "mcp-remote@latest", "https://mcp.atlassian.com/v1/mcp/authv2"],
      "enabled": true,
      "timeout": 30000
    },
    "figma": {
      "type": "remote",
      "url": "http://127.0.0.1:3845/mcp",
      "enabled": true
    }
  },
  "instructions": ["~/.claude/CLAUDE.md"],
  "permission": {
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "skill": "allow",
    "bash": "allow",
    "external_directory": {
      "~/.claude/**": "allow",
      "~/.claude/repo-context/*": "allow",
      "~/Developer/work/**": "allow",
      "~/Developer/personal/**": "allow",
      "~/dotfiles/**": "allow",
      "/tmp/**": "allow"
    }
  }
}
