{
  "permissions": {
    "allow": [
      "Bash(ls ~/Developer/work/:*)",
      "Bash(ls ~/Developer/personal/:*)",
      "Bash(mkdir -p ~/.claude/repo-context)",
      "Bash(ls ~/.claude/repo-context/:*)",
      "Bash(git:*)",
      "Bash(gh issue create:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Write(~/.claude/repo-context/*)",
      "Edit(~/.claude/**)",
      "Write(~/.claude/**)",
      "Edit(CLAUDE.md)",
      "Read",
      "Grep",
      "WebFetch",
      "WebSearch"
    ],
    "defaultMode": "auto",
    "additionalDirectories": [
      "~/Developer/work",
      "~/Developer/personal"
    ]
  },
  "model": "opus[1m]",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /Users/tobias/.claude/hooks/guard-piped-exit-code.py",
            "statusMessage": "Checking for masked pipeline exit code"
          },
          {
            "type": "command",
            "command": "python3 /Users/tobias/.claude/hooks/guard-sim-against-prod.py",
            "statusMessage": "Checking simulator is not pointed at production"
          }
        ]
      },
      {
        "matcher": "Read|SendUserFile",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/tobias/.claude/hooks/remind-batch-images.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "swift-lsp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    }
  },
  "effortLevel": "high",
  "tui": "fullscreen",
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark",
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true
}
